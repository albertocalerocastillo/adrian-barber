# Copia este archivo a .env y rellena con tus valores de Supabase
# (Supabase -> Project Settings -> API). Se usará a partir de la Fase 2.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Aviso de cita nueva por WhatsApp (CallMeBot, opcional).
# Ver https://www.callmebot.com/blog/free-api-whatsapp-messages/
VITE_CALLMEBOT_PHONE=34XXXXXXXXX
VITE_CALLMEBOT_APIKEY=tu-apikey-de-callmebot
